<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Formato de papel Oficio (216 x 330 mm) con márgenes mínimos para que quepan 4 recibos -->
  <record id="paperformat_oficio_recibos" model="report.paperformat">
    <field name="name">Oficio - Recibos (4 por hoja)</field>
    <field name="format">custom</field>
    <field name="page_height">330</field>
    <field name="page_width">216</field>
    <field name="orientation">Portrait</field>
    <field name="margin_top">5</field>
    <field name="margin_bottom">5</field>
    <field name="margin_left">5</field>
    <field name="margin_right">5</field>
    <field name="header_line" eval="False" />
    <field name="header_spacing">0</field>
    <field name="dpi">90</field>
  </record>

  <!-- Acción del reporte -->
  <record id="action_report_recibo_residencia_mensual_masivo" model="ir.actions.report">
    <field name="name">Recibos Mensuales (Proceso Masivo)</field>
    <field name="model">asovec.contador.lines</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">iit_asovec.report_recibo_residencia_mensual_masivo</field>
    <field name="report_file">iit_asovec.report_recibo_residencia_mensual_masivo</field>
    <field name="print_report_name">'Recibos Mensuales'</field>
    <field name="paperformat_id" ref="paperformat_oficio_recibos" />
  </record>

  <!-- Template: 4 recibos por hoja (oficio), en franjas horizontales apiladas (una debajo de
       otra, cada una ocupando todo el ancho de la hoja), reutilizando la misma card del reporte
       individual. Cada hoja es su propio "article" (documento independiente): así wkhtmltopdf
       procesa el PDF hoja por hoja en vez de armar un solo bloque gigante con todas las hojas
       juntas, lo cual rompía la generación cuando el proyecto tenía muchas residencias. -->
  <template id="report_recibo_residencia_mensual_masivo">
    <t t-call="web.html_container">
      <t t-foreach="paginas" t-as="pagina">
        <div class="article">
          <div t-attf-style="#{'' if pagina_last else 'page-break-after: always;'}">
            <table style="width:206mm; height:320mm; border-collapse:separate; border-spacing:0 4mm; table-layout:fixed;">
              <tr t-foreach="[0, 1, 2, 3]" t-as="slot">
                <td style="height:25%; vertical-align:top; padding:0;">
                  <t t-set="rec" t-value="pagina[slot] if len(pagina) > slot else False" />
                  <t t-if="rec">
                    <t t-call="iit_asovec.recibo_residencia_lectura_card" />
                  </t>
                </td>
              </tr>
            </table>
          </div>
        </div>
      </t>
    </t>
  </template>

</odoo>
