<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_asovec_proceso_carga_pagos_banco_wizard_form" model="ir.ui.view">
      <field name="name">asovec.proceso_carga_pagos_banco_wizard.form</field>
      <field name="model">asovec.proceso_carga_pagos_banco_wizard</field>
      <field name="arch" type="xml">
        <form string="Carga de Pagos del Banco">
          <sheet>
            <group>
              <field name="archivo_filename" invisible="1" />
              <field name="archivo"
                filename="archivo_filename"
                widget="binary"
                readonly="line_ids"
                string="Archivo CSV" />
            </group>

            <group string="Parámetros">
              <field name="mes" readonly="line_ids" />
              <field name="anio" readonly="line_ids" />
              <field name="journal_ids" widget="many2many_tags" readonly="line_ids" />
            </group>

            <group>
              <field name="state" widget="badge"
                decoration-success="state in ('validado','completo')"
                decoration-info="state == 'procesando'"
                decoration-danger="state == 'con_error'" />
              <field name="total_filas" />
              <field name="total_generados" />
              <field name="total_errores" />
              <field name="total_errores_pago" invisible="total_errores_pago == 0" />
            </group>

            <div class="alert alert-danger" role="alert" invisible="total_pendientes_validar == 0">
              <strong>
                Pendientes <field name="total_pendientes_validar" nolabel="1" class="oe_inline" readonly="1" /> de validar
              </strong>
            </div>
            <div class="alert alert-danger" role="alert" invisible="total_pendientes_pagar == 0 or total_errores &gt; 0">
              <strong>
                Pendientes <field name="total_pendientes_pagar" nolabel="1" class="oe_inline" readonly="1" /> de generar pago
              </strong>
            </div>
            <div class="alert alert-danger" role="alert" invisible="total_errores_pago == 0">
              <strong>
                ¡Atención! <field name="total_errores_pago" nolabel="1" class="oe_inline" readonly="1" /> residencia(s)
                fallaron al GENERAR/CONFIRMAR el pago (por ejemplo, un rechazo de Hacienda). Revísalas en
                la pestaña "Filas con error" (columna Etapa = "Generación de pago") y corrígelas subiendo
                un CSV nuevo que cuadre solo con esas residencias.
              </strong>
            </div>

            <group invisible="not log">
              <field name="log" nolabel="1" colspan="2" readonly="1" />
            </group>

            <!-- Solo se muestran las filas con error a propósito: una vez que una fila
                 queda validada/procesada sin error, ya no aporta nada revisarla en
                 pantalla (y con cientos de filas, mostrarlas todas es puro ruido). Para
                 revisar los pagos generados, están en el registro de pagos normal de
                 Contabilidad. -->
            <notebook invisible="total_errores == 0">
              <page string="Filas con error" name="filas_error">
                <div class="mb-2">
                  <button name="action_exportar_errores_excel" type="object"
                    string="📄 Descargar errores a Excel" class="btn-secondary" />
                </div>
                <field name="file_name" invisible="1" />
                <field name="file_data" filename="file_name" widget="binary"
                  readonly="1" string="Excel generado" invisible="not file_data" />
                <field name="line_ids" domain="[('error', '!=', False)]">
                  <tree editable="false" decoration-danger="error">
                    <field name="correlativo" />
                    <field name="residencia_code" />
                    <field name="residencia_id" />
                    <field name="nombre" />
                    <field name="cuota" />
                    <field name="saldo" />
                    <field name="saldo_mes_calculado" />
                    <field name="saldo_anterior_calculado" />
                    <field name="etapa_error" />
                    <field name="error" />
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>

          <footer>
            <button name="action_validar" type="object" string="Validar"
              class="btn-primary" invisible="state not in ('draft','con_error')" />
            <button name="action_generar_pagos" type="object" string="Generar Pagos"
              class="btn-primary" invisible="state not in ('validado','procesando')" />
            <button string="Cerrar" special="cancel" class="btn-secondary" />
          </footer>
        </form>
      </field>
    </record>

    <record id="action_proceso_carga_pagos_banco_wizard" model="ir.actions.act_window">
      <field name="name">Carga de Pagos del Banco</field>
      <field name="res_model">asovec.proceso_carga_pagos_banco_wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
    </record>

  </data>
</odoo>
