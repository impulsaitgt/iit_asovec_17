<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_asovec_proceso_lecturas_csv_wizard_form" model="ir.ui.view">
      <field name="name">asovec.proceso_lecturas_csv_wizard.form</field>
      <field name="model">asovec.proceso_lecturas_csv_wizard</field>
      <field name="arch" type="xml">
        <form string="Generar CSV de Lecturas (Todos los Proyectos)">
          <sheet>
            <group>
              <field name="mes" />
              <field name="anio" />
              <field name="proyecto_aso_ids" widget="many2many_tags" />
            </group>

            <group invisible="not file_data">
              <field name="file_name" invisible="1" />
              <field name="file_data"
                filename="file_name"
                widget="binary"
                readonly="1"
                string="Archivo generado" />
            </group>

            <footer>
              <button name="action_generar" type="object" string="Generar (Con Lectura)" class="btn-primary" />
              <button name="action_generar_inactivos" type="object" string="Generar Inactivos" class="btn-secondary" />
              <button name="action_generar_sin_lectura" type="object" string="Generar Sin Lectura" class="btn-secondary" />
              <button string="Cerrar" special="cancel" class="btn-secondary" />
            </footer>
          </sheet>
        </form>
      </field>
    </record>

  </data>
</odoo>
