<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_asovec_lectura_listado_wizard_form" model="ir.ui.view">
      <field name="name">asovec.lectura_listado_wizard.form</field>
      <field name="model">asovec.lectura_listado_wizard</field>
      <field name="arch" type="xml">
        <form string="Listado de Residencias por Proyecto">
          <sheet>
            <group>
              <field name="proyecto_aso_id" options="{'no_create': True}" />
              <field name="mes" />
              <field name="anio" />
            </group>

            <footer>
              <button name="action_buscar" type="object" string="Buscar" class="btn-primary" />
              <button string="Cerrar" special="cancel" class="btn-secondary" />
            </footer>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_asovec_lectura_listado_wizard_line_tree" model="ir.ui.view">
      <field name="name">asovec.lectura_listado_wizard_line.tree</field>
      <field name="model">asovec.lectura_listado_wizard_line</field>
      <field name="arch" type="xml">
        <tree string="Residencias" create="0" edit="0" delete="0" default_order="residencia_codigo">
          <button name="action_ir_a_registrar" type="object"
              string="💧 Registrar" class="btn-primary" icon="fa-tint" />
          <field name="residencia_id" string="Residencia" />
          <field name="contador_id" />
          <field name="direccion_real" />
          <field name="cliente_id" />
          <field name="lectura_anterior" />
          <field name="lectura_actual" invisible="not tiene_lectura" />
          <field name="tiene_lectura" column_invisible="1" />
          <field name="estado_lectura" widget="badge" string="Estado"
              decoration-success="estado_lectura == 'con_lectura'"
              decoration-warning="estado_lectura == 'pendiente'" />
        </tree>
      </field>
    </record>

    <record id="view_asovec_lectura_listado_wizard_line_search" model="ir.ui.view">
      <field name="name">asovec.lectura_listado_wizard_line.search</field>
      <field name="model">asovec.lectura_listado_wizard_line</field>
      <field name="arch" type="xml">
        <search string="Buscar Residencias">
          <field name="residencia_id" />
          <field name="direccion_real" />
          <field name="cliente_id" />

          <filter string="Pendientes" name="pendientes" domain="[('tiene_lectura','=',False)]" />
          <separator />
          <filter string="Activas" name="activas" domain="[('residencia_activa','=',True)]" />
        </search>
      </field>
    </record>

  </data>
</odoo>
