<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_account_payment_form_inherit_aso_banco" model="ir.ui.view">
      <field name="name">account.payment.form.inherit.aso.banco</field>
      <field name="model">account.payment</field>
      <field name="inherit_id" ref="account.view_account_payment_form"/>
      <field name="arch" type="xml">
        <notebook name="payment_notebook" position="inside">
          <page string="Datos del Banco (Asociación)" name="aso_datos_banco"
            invisible="not aso_pago_banco_correlativo">
            <group>
              <group>
                <field name="aso_pago_banco_correlativo" readonly="1"/>
                <field name="aso_pago_banco_codigo" readonly="1"/>
                <field name="aso_pago_banco_fecha" readonly="1"/>
                <field name="aso_pago_banco_agencia" readonly="1"/>
                <field name="aso_pago_banco_pago_con_tc" readonly="1"/>
              </group>
              <group>
                <field name="aso_pago_banco_efectivo" readonly="1"/>
                <field name="aso_pago_banco_cheque_bi" readonly="1"/>
                <field name="aso_pago_banco_cheque_ob" readonly="1"/>
                <field name="aso_pago_banco_cheque_be" readonly="1"/>
                <field name="aso_pago_banco_no_chq_ob" readonly="1"/>
                <field name="aso_pago_banco_no_boleta" readonly="1"/>
                <field name="aso_pago_banco_monto_total" readonly="1"/>
              </group>
            </group>
          </page>
        </notebook>
      </field>
    </record>

  </data>
</odoo>
