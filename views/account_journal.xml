<?xml version="1.0" ?>

<odoo>
    <record id="account_journal_form_ihnerit" model="ir.ui.view">
        <field name="name">account.journal.inherited</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="before">
                <group string="Asociación de Vecinos">
                    <field name="aso_cargo_migrado"/>
                    <field name="aso_cargo_automatico"/>
                    <field name="aso_valida_residencia"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
