<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE -->
    <record id="view_asovec_proyecto_cobro_mensual_tree" model="ir.ui.view">
        <field name="name">asovec.proyecto_cobro_mensual.tree</field>
        <field name="model">asovec.proyecto_cobro_mensual</field>
        <field name="arch" type="xml">
            <tree string="Cobros mensuales" default_order="year desc, month desc">
                <field name="name" />
                <field name="proyecto_aso_id" />
                <field name="month" />
                <field name="currency_id" invisible="1" />
                <field name="year" />
                <field name="total_to_charge" />
                <field name="total_paid" />
                <field name="total_balance" />
                <field name="fecha_confirmacion" optional="hide" />
                <field name="state" string="Estado"
                    widget="badge"
                    decoration-danger="state == 'cancel'"
                    decoration-success="state == 'posted'"
                    decoration-info="state == 'draft'"
                    optional="hide" />
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_asovec_proyecto_cobro_mensual_form" model="ir.ui.view">
        <field name="name">asovec.proyecto_cobro_mensual.form</field>
        <field name="model">asovec.proyecto_cobro_mensual</field>
        <field name="arch" type="xml">
            <form string="Cobro mensual">
                <header>
                    <!-- Botón Generar: solo en borrador. Completa las residencias que aún no
                         tienen cargo y regenera (borra y vuelve a crear) las que siguen en
                         borrador o canceladas; si alguna ya está posteada, se detiene con error. -->
                    <button name="action_generate"
                        type="object"
                        string="Completar Faltantes"
                        class="btn-primary"
                        invisible="state != 'draft'" />

                    <!-- Botón Confirmar: solo en borrador -->
                    <button name="action_confirm"
                        type="object"
                        string="Confirmar"
                        class="btn-primary"
                        invisible="state != 'draft'" />

                    <!-- Opcional: regresar a borrador -->
                    <button name="action_set_draft"
                        type="object"
                        string="Regresar a borrador"
                        class="btn-secondary"
                        invisible="state != 'posted'" />


                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancel" />
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="proyecto_aso_id" options="{'no_create': False}" />
                            <field name="month" />
                            <field name="year" />
                            <field name="fecha_confirmacion" invisible="not fecha_confirmacion" />
                        </group>
                        <group>
                            <field name="currency_id" invisible="1" />
                            <field name="total_to_charge" readonly="1" />
                            <field name="total_paid" readonly="1" />
                            <field name="total_balance" readonly="1" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Detalle">
                            <field name="line_ids">
                                <tree create="0" edit="0" delete="0">
                                    <field name="residencia_id"
                                        options="{'no_create': True, 'no_open': False}" />

                                    <field name="move_id" string="Cargo"/>

                                    <field name="amount_total" readonly="1" />
                                    <field name="amount_residual" readonly="1" />

                                    <field name="move_state"
                                        string="Estado cargo"
                                        widget="badge"
                                        decoration-info="move_state == 'draft'"
                                        decoration-success="move_state == 'posted'"
                                        decoration-danger="move_state == 'cancel'" />
                                    <field name="payment_state" widget="badge"
                                        decoration-info="payment_state == 'partial'"
                                        decoration-success="payment_state == 'paid'"
                                        decoration-danger="payment_state == 'not_paid'" />
                                    <field name="con_lectura" widget="badge"
                                        decoration-info="con_lectura == 'Inactivo'"
                                        decoration-success="con_lectura == 'Lectura Valida'"
                                        decoration-danger="con_lectura == 'Sin Lectura'" />
                                    <!--                                    widget="badge"
                                        options="{'true_label': 'Con lectura', 'false_label': 'Sin lectura'}"
                                        decoration-success="con_lectura"
                                        decoration-danger="not con_lectura" /> -->
                                </tree>

                                <!-- Este form es de la LÍNEA, no de la residencia -->
                                <form string="Detalle de residencia" edit="false" create="false"
                                    delete="false">
                                    <header>
                                        <button name="action_imprimir_recibo"
                                            type="object"
                                            string="Imprimir Recibo"
                                            class="btn-primary"
                                            icon="fa-file-pdf-o"
                                            invisible="not contador_line_id" />
                                    </header>
                                    <field name="contador_line_id" invisible="1" />
                                    <group>
                                        <field name="residencia_id" readonly="1"
                                            options="{'no_create': True, 'no_open': False}" />
                                        <field name="move_id" readonly="1"
                                            options="{'no_create': True, 'no_open': False}" />
                                        <field name="move_state" widget="badge"
                                            decoration-info="move_state == 'draft'"
                                            decoration-success="move_state == 'posted'"
                                            decoration-danger="move_state == 'cancel'" />
                                        <field name="payment_state" widget="badge"
                                            decoration-info="payment_state == 'partial'"
                                            decoration-success="payment_state == 'paid'"
                                            decoration-danger="payment_state == 'not_paid'" />
                                    </group>
                                    <group>
                                        <field name="currency_id" invisible="1" />
                                        <field name="amount_total" readonly="1" />
                                        <field name="amount_balance" readonly="1" />
                                        <field name="con_lectura" widget="badge" readonly="1"
                                            decoration-info="con_lectura == 'Inactivo'"
                                            decoration-success="con_lectura == 'Lectura Valida'"
                                            decoration-danger="con_lectura == 'Sin Lectura'" />
                                    </group>
                                    <group string="Lectura" invisible="not contador_line_id">
                                        <field name="lectura_anterior" readonly="1" />
                                        <field name="lectura_actual" readonly="1" />
                                        <field name="exceso" readonly="1" />
                                    </group>
                                    <group string="Cobro" invisible="not contador_line_id">
                                        <field name="base" readonly="1" />
                                        <field name="pago_extra" readonly="1" />
                                        <field name="pago_total" readonly="1" />
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_asovec_proyecto_cobro_mensual_search" model="ir.ui.view">
        <field name="name">asovec.proyecto_cobro_mensual.search</field>
        <field name="model">asovec.proyecto_cobro_mensual</field>
        <field name="arch" type="xml">
            <search string="Buscar cobros mensuales">
                <field name="name" />
                <field name="proyecto_aso_id" />
                <field name="month" />
                <field name="year" />
                <field name="state" />
                <filter string="Borrador" name="draft" domain="[('state','=','draft')]" />
                <filter string="Publicado" name="posted" domain="[('state','=','posted')]" />
                <filter string="Cancelado" name="cancel" domain="[('state','=','cancel')]" />
                <group expand="0" string="Agrupar por">
                    <filter string="Proyecto" name="grp_proyecto_aso"
                        context="{'group_by':'proyecto_aso_id'}" />
                    <filter string="Año" name="grp_year" context="{'group_by':'year'}" />
                    <filter string="Mes" name="grp_month" context="{'group_by':'month'}" />
                </group>
            </search>
        </field>
    </record>

</odoo>