<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE -->
    <record id="view_asovec_proyecto_cobro_mensual_tree" model="ir.ui.view">
        <field name="name">asovec.proyecto_cobro_mensual.tree</field>
        <field name="model">asovec.proyecto_cobro_mensual</field>
        <field name="arch" type="xml">
            <tree string="Cobros mensuales" default_order="year desc, month desc, proyecto_indice asc">
                <field name="name" />
                <field name="proyecto_aso_id" />
                <field name="month" />
                <field name="currency_id" column_invisible="1" />
                <field name="year" />
                <field name="total_to_charge" />
                <field name="total_paid" />
                <field name="total_balance" />
                <field name="residencias_sin_lectura" string="Lecturas pendientes" />
                <field name="fecha_confirmacion" optional="hide" />
                <field name="state" string="Estado"
                    widget="badge"
                    decoration-danger="state == 'cancel'"
                    decoration-success="state == 'posted'"
                    decoration-info="state == 'draft'"
                    optional="hide" />
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_asovec_proyecto_cobro_mensual_form" model="ir.ui.view">
        <field name="name">asovec.proyecto_cobro_mensual.form</field>
        <field name="model">asovec.proyecto_cobro_mensual</field>
        <field name="arch" type="xml">
            <form string="Cobro mensual">
                <header>
                    <!-- Botón Generar: solo en borrador. Completa las residencias que aún no
                         tienen cargo y regenera (borra y vuelve a crear) las que siguen en
                         borrador o canceladas; si alguna ya está posteada, se detiene con error.
                         Solo para pruebas/soporte: visible únicamente para el grupo
                         Administrador (no para Administración Asociación ni Secretaria). -->
                    <button name="action_generate"
                        type="object"
                        string="Completar Faltantes"
                        class="btn-primary"
                        invisible="state != 'draft'"
                        groups="iit_asovec.asovec_group_administrador" />

                    <!-- Igual que "Completar Faltantes" pero solo para las residencias
                         inactivas del proyecto (mismo motor, ver _generar_lote). -->
                    <button name="action_generate_inactivas"
                        type="object"
                        string="Completar Inactivas"
                        class="btn-primary"
                        invisible="state != 'draft'" />

                    <!-- Borra y regenera TODOS los cargos ya existentes de este cobro
                         mensual con la configuración vigente (precios, cuentas contables
                         por proyecto, etc.) - para validar cambios de configuración sin
                         corregir residencia por residencia. Solo Administrador. -->
                    <button name="action_regenerar_cargos"
                        type="object"
                        string="🔄 Regenerar Cargos"
                        class="btn-secondary"
                        confirm="Esto borra TODOS los cargos ya generados de este cobro mensual (los que no estén posteados) y los vuelve a crear con la configuración vigente. ¿Continuar?"
                        invisible="state != 'draft'"
                        groups="iit_asovec.asovec_group_administrador" />

                    <!-- Botón Confirmar: solo en borrador, y solo cuando ya no queda
                         ninguna residencia pendiente por generar (mismo criterio que
                         "Completar Faltantes", no exige que TODAS tengan un cargo/factura
                         real: una residencia con lectura pero sin nada que cobrar ese mes
                         también cuenta como resuelta). -->
                    <button name="action_confirm"
                        type="object"
                        string="Confirmar"
                        class="btn-primary"
                        invisible="state != 'draft' or residencias_pendientes != 0" />

                    <!-- Opcional: regresar a borrador -->
                    <button name="action_set_draft"
                        type="object"
                        string="Regresar a borrador"
                        class="btn-secondary"
                        invisible="state != 'posted'" />

                    <!-- Refresca este mismo registro (indicadores, estados de línea) sin
                         recargar toda la página: útil mientras se reciben lecturas en vivo. -->
                    <button name="action_refrescar"
                        type="object"
                        string="🔄 Refrescar"
                        class="btn-secondary" />

                    <!-- Exporta a CSV las residencias con lectura válida ingresada hasta el
                         momento, para que la secretaria pueda revisarlas. -->
                    <button name="action_exportar_csv"
                        type="object"
                        string="📄 Exportar CSV"
                        class="btn-secondary" />

                    <!-- Exporta a CSV las residencias/contadores inactivos, para revisar si
                         alguna debe reactivarse. -->
                    <button name="action_exportar_csv_inactivas"
                        type="object"
                        string="⚠ Exportar Inactivos"
                        class="btn-secondary" />

                    <!-- Exporta a CSV las residencias activas que todavía no tienen lectura
                         este período, para ver qué falta. -->
                    <button name="action_exportar_csv_sin_lectura"
                        type="object"
                        string="📋 Exportar Sin Lectura"
                        class="btn-secondary" />

                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancel" />
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_residencias_total" type="object"
                            class="oe_stat_button" icon="fa-home">
                            <field name="total_residencias" widget="statinfo" string="Residencias" />
                        </button>
                        <button name="action_ver_residencias_con_lectura" type="object"
                            class="oe_stat_button" icon="fa-tint">
                            <field name="residencias_con_lectura" widget="statinfo" string="Con lectura" />
                            <field name="pct_con_lectura" widget="percentage" />
                        </button>
                        <button name="action_ver_residencias_sin_lectura" type="object"
                            class="oe_stat_button" icon="fa-question-circle">
                            <field name="residencias_sin_lectura" widget="statinfo" string="Sin lectura" />
                            <field name="pct_sin_lectura" widget="percentage" />
                        </button>
                        <button name="action_ver_residencias_inactivas" type="object"
                            class="oe_stat_button" icon="fa-ban">
                            <field name="residencias_inactivas" widget="statinfo" string="Inactivas" />
                            <field name="pct_inactivas" widget="percentage" />
                        </button>
                        <button name="action_ver_cargos_generados" type="object"
                            class="oe_stat_button" icon="fa-file-text-o">
                            <field name="residencias_cargo_generado" widget="statinfo" string="Cargos generados" />
                            <field name="pct_cargo_generado" widget="percentage" />
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                        <field name="progreso_tipo" invisible="1" />
                        <field name="residencias_pendientes" invisible="1" />
                        <field name="progreso_label" widget="badge" nolabel="1"
                            decoration-danger="progreso_tipo == 'danger'"
                            decoration-success="progreso_tipo == 'success'" />
                    </div>

                    <group>
                        <group>
                            <field name="proyecto_aso_id" options="{'no_create': False}" />
                            <field name="month" />
                            <field name="year" />
                            <field name="fecha_confirmacion" invisible="not fecha_confirmacion" />
                        </group>
                        <group>
                            <field name="currency_id" invisible="1" />
                            <field name="total_to_charge" readonly="1" />
                            <field name="total_paid" readonly="1" />
                            <field name="total_balance" readonly="1" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Detalle">
                            <field name="line_ids">
                                <tree create="0" edit="0" delete="0">
                                    <field name="residencia_id"
                                        options="{'no_create': True, 'no_open': False}" />
                                    <field name="cliente_id" string="Residente" />

                                    <field name="move_id" string="Cargo"/>

                                    <field name="lectura_anterior" readonly="1" />
                                    <field name="lectura_actual" readonly="1" />
                                    <field name="consumo" readonly="1" />
                                    <field name="exceso" readonly="1" decoration-danger="exceso > 0" />

                                    <field name="amount_total" readonly="1" decoration-danger="exceso > 0" />
                                    <field name="amount_residual" readonly="1" />

                                    <field name="move_state"
                                        string="Estado cargo"
                                        widget="badge"
                                        decoration-info="move_state == 'draft'"
                                        decoration-success="move_state == 'posted'"
                                        decoration-danger="move_state == 'cancel'" />
                                    <field name="payment_state" widget="badge"
                                        decoration-info="payment_state == 'partial'"
                                        decoration-success="payment_state == 'paid'"
                                        decoration-danger="payment_state == 'not_paid'" />
                                    <field name="con_lectura" widget="badge"
                                        decoration-info="con_lectura == 'Inactivo'"
                                        decoration-success="con_lectura == 'Lectura Valida'"
                                        decoration-danger="con_lectura == 'Sin Lectura'" />
                                    <!--                                    widget="badge"
                                        options="{'true_label': 'Con lectura', 'false_label': 'Sin lectura'}"
                                        decoration-success="con_lectura"
                                        decoration-danger="not con_lectura" /> -->
                                </tree>

                                <!-- Este form es de la LÍNEA, no de la residencia -->
                                <form string="Detalle de residencia" edit="false" create="false"
                                    delete="false">
                                    <header>
                                        <!-- Corregir la lectura desde AQUÍ (en vez de editar
                                             "Lectura actual" en este mismo formulario) porque
                                             corregirla regenera el cargo, lo que borra y recrea
                                             esta misma línea a mitad de su propio write(). El
                                             formulario normal de asovec.contador.lines sí
                                             sobrevive a esa regeneración. -->
                                        <button name="action_corregir_lectura"
                                            type="object"
                                            string="✏️ Corregir Lectura"
                                            class="btn-primary"
                                            invisible="not contador_line_id" />
                                        <button name="action_imprimir_recibo"
                                            type="object"
                                            string="Imprimir Recibo"
                                            class="btn-primary"
                                            icon="fa-file-pdf-o"
                                            invisible="not contador_line_id" />
                                        <button name="action_imprimir_cargo"
                                            type="object"
                                            string="🖨️ Imprimir Recibo Detallado"
                                            class="btn-primary"
                                            icon="fa-file-pdf-o" />
                                        <!-- Solo para validar configuración (precios, cuentas
                                             contables por proyecto, etc.): borra y regenera el
                                             cargo de ESTA residencia con los valores vigentes.
                                             No aparece si ya está posteado (ahí ni se podría
                                             regenerar). -->
                                        <button name="action_regenerar_cargo"
                                            type="object"
                                            string="🔄 Regenerar Cargo"
                                            class="btn-secondary"
                                            confirm="Esto borra el cargo actual de esta residencia y lo vuelve a generar con la configuración vigente. ¿Continuar?"
                                            invisible="move_state == 'posted'"
                                            groups="iit_asovec.asovec_group_administrador,iit_asovec.asovec_group_administracion_asociacion,iit_asovec.asovec_group_secretaria_asociacion" />
                                    </header>
                                    <field name="contador_line_id" invisible="1" />
                                    <group>
                                        <field name="residencia_id" readonly="1"
                                            options="{'no_create': True, 'no_open': False}" />
                                        <field name="cliente_id" string="Residente" readonly="1"
                                            options="{'no_create': True, 'no_open': False}" />
                                        <field name="move_id" readonly="1"
                                            options="{'no_create': True, 'no_open': False}" />
                                        <field name="move_state" widget="badge"
                                            decoration-info="move_state == 'draft'"
                                            decoration-success="move_state == 'posted'"
                                            decoration-danger="move_state == 'cancel'" />
                                        <field name="payment_state" widget="badge"
                                            decoration-info="payment_state == 'partial'"
                                            decoration-success="payment_state == 'paid'"
                                            decoration-danger="payment_state == 'not_paid'" />
                                    </group>
                                    <group>
                                        <field name="currency_id" invisible="1" />
                                        <field name="amount_total" readonly="1" />
                                        <field name="amount_balance" readonly="1" />
                                        <field name="con_lectura" widget="badge" readonly="1"
                                            decoration-info="con_lectura == 'Inactivo'"
                                            decoration-success="con_lectura == 'Lectura Valida'"
                                            decoration-danger="con_lectura == 'Sin Lectura'" />
                                    </group>
                                    <group string="Lectura" invisible="not contador_line_id">
                                        <field name="lectura_anterior" readonly="1" />
                                        <field name="lectura_actual" readonly="1" />
                                        <field name="exceso" readonly="1" decoration-danger="exceso > 0" />
                                    </group>
                                    <group string="Cobro" invisible="not contador_line_id">
                                        <field name="base" readonly="1" />
                                        <field name="pago_extra" readonly="1" decoration-danger="pago_extra > 0" />
                                        <field name="pago_total" readonly="1" />
                                    </group>
                                    <group invisible="not contador_line_id">
                                        <field name="foto_filename" invisible="1" />
                                        <field name="foto" widget="image"
                                            options="{'size': [200, 200]}"
                                            filename="foto_filename"
                                            string="Foto de la lectura" />
                                        <field name="foto" widget="binary"
                                            filename="foto_filename"
                                            invisible="not foto"
                                            string="Descargar foto" />
                                        <field name="observaciones" readonly="1" />
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_asovec_proyecto_cobro_mensual_search" model="ir.ui.view">
        <field name="name">asovec.proyecto_cobro_mensual.search</field>
        <field name="model">asovec.proyecto_cobro_mensual</field>
        <field name="arch" type="xml">
            <search string="Buscar cobros mensuales">
                <field name="name" />
                <field name="proyecto_aso_id" />
                <field name="month" />
                <field name="year" />
                <field name="state" />
                <filter string="Borrador" name="draft" domain="[('state','=','draft')]" />
                <filter string="Publicado" name="posted" domain="[('state','=','posted')]" />
                <filter string="Cancelado" name="cancel" domain="[('state','=','cancel')]" />
                <group expand="0" string="Agrupar por">
                    <filter string="Proyecto" name="grp_proyecto_aso"
                        context="{'group_by':'proyecto_aso_id'}" />
                    <filter string="Año" name="grp_year" context="{'group_by':'year'}" />
                    <filter string="Mes" name="grp_month" context="{'group_by':'month'}" />
                </group>
            </search>
        </field>
    </record>

</odoo>