<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_asovec_proceso_carga_deudas_wizard_form" model="ir.ui.view">
      <field name="name">asovec.proceso_carga_deudas_wizard.form</field>
      <field name="model">asovec.proceso_carga_deudas_wizard</field>
      <field name="arch" type="xml">
        <form string="Cargar Deudas/Facturas Anteriores">
          <sheet>
            <group>
              <field name="archivo_filename" invisible="1" />
              <field name="archivo"
                filename="archivo_filename"
                widget="binary"
                readonly="line_ids"
                string="Archivo CSV" />
            </group>

            <group string="Columna 4 del CSV">
              <field name="diario_1_id" readonly="line_ids" />
              <field name="mes_1" readonly="line_ids" />
              <field name="anio_1" readonly="line_ids" />
            </group>

            <group string="Columna 5 del CSV">
              <field name="diario_2_id" readonly="line_ids" />
              <field name="mes_2" readonly="line_ids" />
              <field name="anio_2" readonly="line_ids" />
            </group>

            <group>
              <field name="state" widget="badge"
                decoration-success="state in ('completo','confirmado')"
                decoration-warning="state == 'en_proceso'"
                decoration-danger="state == 'con_error'" />
              <field name="total_filas" />
              <field name="total_generados" />
              <field name="total_errores" />
            </group>

            <div class="alert alert-danger" role="alert" invisible="total_pendientes == 0">
              <strong>
                Pendientes <field name="total_pendientes" nolabel="1" class="oe_inline" readonly="1" /> de procesar
              </strong>
            </div>
            <div class="alert alert-danger" role="alert" invisible="total_pendientes_confirmar == 0">
              <strong>
                Pendientes <field name="total_pendientes_confirmar" nolabel="1" class="oe_inline" readonly="1" /> de Confirmar
              </strong>
            </div>

            <group invisible="not log">
              <field name="log" nolabel="1" readonly="1" />
            </group>

            <notebook invisible="not line_ids">
              <page string="Filas con error" name="filas_error" invisible="total_errores == 0">
                <field name="line_ids" domain="[('error', '!=', False)]">
                  <tree editable="false" decoration-danger="error">
                    <field name="residencia_code" />
                    <field name="monto_1" />
                    <field name="monto_2" />
                    <field name="error" />
                  </tree>
                </field>
              </page>
              <page string="Todas las filas" name="todas_las_filas">
                <field name="line_ids">
                  <tree editable="false" decoration-danger="error" decoration-muted="procesado and not error">
                    <field name="residencia_code" />
                    <field name="monto_1" />
                    <field name="monto_2" />
                    <field name="procesado" />
                    <field name="error" />
                    <field name="move_1_id" />
                    <field name="move_2_id" />
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>

          <footer>
            <button name="action_procesar" type="object" string="Procesar"
              class="btn-primary" invisible="state == 'confirmado'" />
            <button name="action_confirmar_todos" type="object" string="Confirmar Todos"
              class="btn-primary" invisible="state not in ('completo','confirmado')" />
            <button string="Cerrar" special="cancel" class="btn-secondary" />
          </footer>
        </form>
      </field>
    </record>

    <record id="action_proceso_carga_deudas_wizard" model="ir.actions.act_window">
      <field name="name">Cargar Deudas/Facturas Anteriores</field>
      <field name="res_model">asovec.proceso_carga_deudas_wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
    </record>

  </data>
</odoo>

