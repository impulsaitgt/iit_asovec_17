<?xml version="1.0"?>

<odoo>

    <record id="action_product_template_servicios_aso" model="ir.actions.act_window">
        <field name="name">Servicios de Asociación</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[
            ('detailed_type', '=', 'service'),
            ('aso_es_servicio_aso', '=', True)
            ]</field>
    </record>


    <record id="proyecto_aso_action" model="ir.actions.act_window">
        <field name="name">Proyectos</field>
        <field name="res_model">asovec.proyecto_aso</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

    <record id="residencia_action" model="ir.actions.act_window">
        <field name="name">Residencias</field>
        <field name="res_model">asovec.residencia</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

    <record id="contador_action" model="ir.actions.act_window">
        <field name="name">Contadores</field>
        <field name="res_model">asovec.contador</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_activos': 1, 'active_test': False}</field>
    </record>

    <record id="contador_line_action" model="ir.actions.act_window">
        <field name="name">Lecturas</field>
        <field name="res_model">asovec.contador.lines</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="proyecto_cobro_mensual_action" model="ir.actions.act_window">
        <field name="name">Cobros mensuales</field>
        <field name="res_model">asovec.proyecto_cobro_mensual</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_asovec_proyecto_cobro_mensual_search" />
        <field name="context">{}</field>
    </record>

    <record id="cobro_mensual_consulta_wizard_action" model="ir.actions.act_window">
        <field name="name">Consulta Cobros Mensuales</field>
        <field name="res_model">asovec.cobro_mensual_consulta_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_asovec_estado_cuenta_analisis" model="ir.actions.act_window">
        <field name="name">Análisis Estado de Cuenta</field>
        <field name="res_model">asovec.proyecto_cobro_mensual_line</field>
        <field name="view_mode">tree,pivot,graph</field>
        <field name="context">{}</field>
    </record>

    <record id="action_tipo_servicio_aso" model="ir.actions.act_window">
        <field name="name">Tipos de Servicio Asociacion</field>
        <field name="res_model">asovec.tipo_servicio_aso</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <record id="proceso_recibo_masivo_wizard_action" model="ir.actions.act_window">
        <field name="name">Generar Recibos Mensuales</field>
        <field name="res_model">asovec.proceso_recibo_masivo_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="proceso_estado_cuenta_csv_wizard_action" model="ir.actions.act_window">
        <field name="name">Generar CSV de Estado de Cuenta (Banco)</field>
        <field name="res_model">asovec.proceso_estado_cuenta_csv_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="proceso_estado_lecturas_excel_wizard_action" model="ir.actions.act_window">
        <field name="name">Generar Excel de Estado de Lecturas</field>
        <field name="res_model">asovec.proceso_estado_lecturas_excel_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="proceso_lecturas_csv_wizard_action" model="ir.actions.act_window">
        <field name="name">Generar CSV de Lecturas (Todos los Proyectos)</field>
        <field name="res_model">asovec.proceso_lecturas_csv_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="lectura_listado_wizard_action" model="ir.actions.act_window">
        <field name="name">Listado de Residencias por Proyecto</field>
        <field name="res_model">asovec.lectura_listado_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


    <menuitem name="Asociacion de Vecinos" id="asovec_menu" />
    <menuitem name="Asociacion" id="asociacion_menu" parent="asovec_menu" sequence="10" />
    <menuitem name="Proyectos" id="proyecto_aso_opcion" parent="asociacion_menu"
        action="proyecto_aso_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_temporal_implementacion" />
    <menuitem name="Residencias" id="residencia_opcion" parent="asociacion_menu"
        action="residencia_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_temporal_implementacion" />

    <menuitem name="Contadores" id="contadores_menu" parent="asovec_menu" sequence="20" />
    <menuitem name="Contadores" id="contador_opcion" parent="contadores_menu"
        action="contador_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_temporal_implementacion" />
    <menuitem name="Lecturas de Contador" id="contador_line_opcion" parent="contadores_menu"
        action="contador_line_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_temporal_implementacion" />

    <!-- Sección propia para el trabajo de campo (rol operador de lecturas): separado
         de "Contadores" (catálogo/admin) para que el operador tenga su propio menú
         con nombre claro para su tarea del día a día. -->
    <menuitem name="Toma de Lecturas" id="toma_lecturas_menu" parent="asovec_menu" sequence="25" />
    <menuitem name="Listado de Residencias por Proyecto" id="lectura_listado_wizard_opcion" parent="toma_lecturas_menu"
        action="lectura_listado_wizard_action" sequence="3"
        groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_operador_lecturas" />
    <menuitem name="Registrar Lectura" id="lectura_operador_wizard_opcion" parent="toma_lecturas_menu"
        action="lectura_operador_wizard_action" sequence="5"
        groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_operador_lecturas" />

    <menuitem name="Mantenimientos" id="mantenimientos_menu" parent="asovec_menu" sequence="30" />
    <menuitem name="Tipos Servicios Aso" id="tipo_servicio_aso_opcion" parent="mantenimientos_menu"
        sequence="31"
        action="action_tipo_servicio_aso" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />
    <menuitem name="Residentes" id="clientes_opcion" parent="mantenimientos_menu" sequence="32"
        action="account.res_partner_action_customer" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />
    <menuitem name="Servicios" id="productos_opcion" parent="mantenimientos_menu" sequence="33"
        action="action_product_template_servicios_aso" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />

    <menuitem name="Movimientos" id="movimientos_menu" parent="asovec_menu" sequence="40" />
    <menuitem name="Facturas y Cargos" id="facturas_cargos_opcion" parent="movimientos_menu"
        action="account.action_move_out_invoice_type" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion"/>
    <menuitem name="Pagos" id="pagos_opcion" parent="movimientos_menu"
        action="account.action_account_payments" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion"/>

    <!-- Ciclo mensual recurrente, en orden: generar cargos, generar recibos, conciliar
         banco (exportar estado de cuenta / cargar pagos). -->
    <menuitem name="Procesos" id="procesos_menu" parent="asovec_menu" sequence="50" />
    <menuitem name="Generacion de Cobros Mensuales" id="proyecto_cobro_mensual"
        parent="procesos_menu" action="proyecto_cobro_mensual_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />
    <menuitem name="Generar Recibos Mensuales" id="proceso_recibo_masivo_opcion"
        parent="procesos_menu" action="proceso_recibo_masivo_wizard_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />
    <menuitem name="Generar CSV de Estado de Cuenta (Banco)" id="proceso_estado_cuenta_csv_opcion"
        parent="procesos_menu" action="proceso_estado_cuenta_csv_wizard_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />
    <menuitem name="Carga de pagos del Banco" id="proceso_carga_pagos_banco_opcion"
        parent="procesos_menu" action="action_proceso_carga_pagos_banco_wizard" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />

    <menuitem name="Consultas" id="consultas_menu" parent="asovec_menu" sequence="60" />
    <menuitem name="Estado de Cuenta" id="estado_de_cuenta" parent="consultas_menu"
        action="cobro_mensual_consulta_wizard_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />
    <menuitem name="Análisis Cobros y Pagos" id="menu_asovec_estado_cuenta_analisis"
        parent="consultas_menu"
        action="action_asovec_estado_cuenta_analisis" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion" />
    <menuitem name="Análisis Mensual de la Asociación" id="proceso_analisis_mensual_opcion"
        parent="consultas_menu" action="proceso_analisis_mensual_wizard_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_temporal_implementacion" />

    <!-- Exportaciones a archivo, separadas de "Consultas" (que son reportes en
         pantalla) para no mezclar ambos tipos de acción en el mismo menú. -->
    <menuitem name="Exportaciones" id="exportaciones_menu" parent="asovec_menu" sequence="65" />
    <menuitem name="Generar Excel de Estado de Lecturas" id="proceso_estado_lecturas_excel_opcion"
        parent="exportaciones_menu" action="proceso_estado_lecturas_excel_wizard_action" groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_temporal_implementacion" />
    <menuitem name="Generar CSV de Lecturas (Todos los Proyectos)" id="proceso_lecturas_csv_opcion"
        parent="exportaciones_menu" action="proceso_lecturas_csv_wizard_action"
        groups="asovec_group_administrador,asovec_group_administracion_asociacion,asovec_group_secretaria_asociacion,asovec_group_operador_lecturas" />

    <!-- Al final: carga inicial/migración, se usa una vez por residencia, no es
         parte del ciclo mensual recurrente ni del catálogo que se mantiene. -->
    <menuitem name="Migración" id="migracion_menu" parent="asovec_menu" sequence="70" />
    <menuitem name="Cargar Deudas/Facturas Anteriores" id="proceso_carga_deudas_opcion"
        parent="migracion_menu" action="action_proceso_carga_deudas_wizard" groups="asovec_group_administrador" />

</odoo>