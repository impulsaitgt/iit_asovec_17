<?xml version="1.0"?>
<odoo>
    <record id="res_company_form_view_aso_inherit" model="ir.ui.view">
        <field name="name">res.company.form.view.aso.inherited</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Asociación de Vecinos">
                    <group>
                        <label for="aso_calculos_mes" string="Cálculos a partir de" />
                        <div class="o_row">
                            <field name="aso_calculos_mes" placeholder="Mes" />
                            <field name="aso_calculos_anio" placeholder="Año" />
                        </div>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
